<div class="gmants-roleplayr-form gmants-roleplayr-import-form">

  <div class="gmants-roleplayr-search-bar">
    <label class="gmants-roleplayr-search-input">
      <i class="fas fa-search" aria-hidden="true"></i>
      <input
        type="text"
        name="searchQuery"
        placeholder="{{localize "GMANTS_ROLEPLAYR.Import.SearchPlaceholder"}}"
        value="{{query}}"
        autocomplete="off"
      />
    </label>
    <select name="sortMode" class="gmants-roleplayr-sort-select" aria-label="{{localize "GMANTS_ROLEPLAYR.Import.SortBy"}}">
      {{#each sortOptions}}
        <option value="{{key}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>
          {{label}}
        </option>
      {{/each}}
    </select>
    <button
      type="button"
      class="gmants-roleplayr-refresh-btn"
      data-action="refresh"
      title="{{localize "GMANTS_ROLEPLAYR.Import.Refresh"}}"
    >
      <i class="fas fa-sync"></i>
    </button>
  </div>

  <div class="gmants-roleplayr-type-bar">
    {{#each types}}
      <button
        type="button"
        class="gmants-roleplayr-type-btn {{#if active}}active{{/if}}"
        data-action="selectType"
        data-type="{{key}}"
      >
        {{label}}
      </button>
    {{/each}}
  </div>

  {{#if loadError}}
    <section class="gmants-roleplayr-test-err">
      <span>{{loadError}}</span>
    </section>
  {{else if isLoading}}
    <section class="gmants-roleplayr-empty">
      <i class="fas fa-spinner fa-spin"></i>
      {{localize "GMANTS_ROLEPLAYR.Import.Loading"}}
    </section>
  {{else if isEmpty}}
    <section class="gmants-roleplayr-empty">
      {{localize "GMANTS_ROLEPLAYR.Import.Empty"}}
    </section>
  {{else}}
    <ul class="gmants-roleplayr-entity-list">
      {{#each entities}}
        <li class="gmants-roleplayr-entity-row">
          <div class="gmants-roleplayr-entity-meta">
            <div class="gmants-roleplayr-entity-name">{{name}}</div>
            <div class="gmants-roleplayr-entity-sub">{{entity_type}}</div>
          </div>
          <label class="gmants-roleplayr-target-type">
            <span class="gmants-roleplayr-target-type-label">{{localize "GMANTS_ROLEPLAYR.Import.ImportAs"}}</span>
            <select name="targetType">
              <option value="character" {{#if isDefaultCharacter}}selected{{/if}}>
                {{localize "GMANTS_ROLEPLAYR.Import.AsCharacter"}}
              </option>
              <option value="npc" {{#if isDefaultNpc}}selected{{/if}}>
                {{localize "GMANTS_ROLEPLAYR.Import.AsNPC"}}
              </option>
            </select>
          </label>
          <button
            type="button"
            class="gmants-roleplayr-primary-btn"
            data-action="importEntity"
            data-entity-id="{{id}}"
          >
            <i class="fas fa-cloud-download-alt"></i>
            {{localize "GMANTS_ROLEPLAYR.Import.ImportButton"}}
          </button>
        </li>
      {{/each}}
    </ul>
    {{#if hasMore}}
      <div class="gmants-roleplayr-load-more">
        <button type="button" data-action="loadMore" {{#if isLoadingMore}}disabled{{/if}}>
          {{#if isLoadingMore}}
            <i class="fas fa-spinner fa-spin"></i>
            {{localize "GMANTS_ROLEPLAYR.Import.LoadingMore"}}
          {{else}}
            {{localize "GMANTS_ROLEPLAYR.Import.LoadMore"}}
          {{/if}}
        </button>
      </div>
    {{/if}}
  {{/if}}

  <footer class="gmants-roleplayr-footer">
    <div class="gmants-roleplayr-footer-right">
      <button type="button" data-action="close">{{localize "GMANTS_ROLEPLAYR.Import.Close"}}</button>
    </div>
  </footer>

</div>
